{
  "name": "@domainproof/mcp",
  "version": "0.1.1",
  "description": "MCP server for DomainProof domain-ownership verification — lets AI agents claim, verify, and monitor domains.",
  "keywords": [
    "domainproof",
    "mcp",
    "model-context-protocol",
    "domain-verification",
    "domain-ownership",
    "dns"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iagodahlem/domainproof.git",
    "directory": "packages/mcp"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "domainproof-mcp": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint ."
  },
  "dependencies": {
    "@domainproof/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "^8.64.0",
    "vitest": "catalog:"
  }
}
