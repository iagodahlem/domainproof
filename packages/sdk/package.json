{
  "name": "@domainproof/sdk",
  "version": "0.1.0",
  "description": "Typed Node.js client for the DomainProof domain-ownership verification API.",
  "keywords": [
    "domainproof",
    "domain-verification",
    "domain-ownership",
    "dns",
    "sdk"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iagodahlem/domainproof.git",
    "directory": "packages/sdk"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "generate": "openapi-typescript http://localhost:3001/v1/openapi.json -o src/generated/openapi-types.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "openapi-typescript": "^7.13.0",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "^8.64.0",
    "vitest": "catalog:"
  }
}
