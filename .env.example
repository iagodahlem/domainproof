# Consolidated reference for every credential and config name DomainProof's
# infra touches — Railway, Cloudflare, Vercel, Neon, Clerk, Resend, and the
# demo API key. This is an ops/human reference, not something any app loads
# directly at runtime — apps/api has its own apps/api/.env.example for that.
#
# Copy to `.env` at the repo root (gitignored), fill in real values, and
# load into a shell with: set -a; . .env; set +a
#
# See .claude/skills/infra-ops/SKILL.md for how each of these gets used.
# No real values belong in this file, ever — names and placeholders only.

# --- Hosting: Railway (apps/api) ---

# Project-scoped access token. Auth header is `Project-Access-Token`, not
# `Authorization: Bearer`. Also used by CI. Mint: Railway dashboard ->
# Project Settings -> Tokens.
RAILWAY_TOKEN=

# Scopes GraphQL queries/mutations to this project. Mint: Railway
# dashboard -> Project Settings -> General.
RAILWAY_PROJECT_ID=

# The environment to target (e.g. production). Mint: Railway dashboard ->
# environment dropdown -> Settings.
RAILWAY_ENVIRONMENT_ID=

# The apps/api service's id — target of deploy-status/logs/redeploy calls.
# Mint: Railway dashboard -> service -> Settings.
RAILWAY_SERVICE_ID=

# --- DNS + WAF: Cloudflare (zone domainproof.dev) ---

# Scoped to the domainproof.dev zone (DNS edit + WAF read at minimum).
# Auth header: `Authorization: Bearer`. Mint: Cloudflare dashboard -> My
# Profile -> API Tokens -> Create Token.
CLOUDFLARE_API_TOKEN=

# Zone id for domainproof.dev. Mint: Cloudflare dashboard ->
# domainproof.dev -> Overview (right sidebar).
CLOUDFLARE_ZONE_ID=

# --- Hosting: Vercel (apps/web) ---

# Account/team token. Mint: Vercel dashboard -> Account Settings -> Tokens.
VERCEL_TOKEN=

# apps/web's Vercel project id. Mint: Vercel dashboard -> project ->
# Settings -> General.
VERCEL_PROJECT_ID=

# --- DB: Neon (Postgres) ---

# Mint: Neon console -> Account Settings -> API Keys.
NEON_API_KEY=

# Mint: Neon console -> project -> Settings -> General.
NEON_PROJECT_ID=

# Connection string for the app's database, same value as apps/api's
# DATABASE_URL. Mint: Neon console -> project -> Connection Details.
DATABASE_URL=

# --- Auth: Clerk (dev instance -> local + staging, prod instance -> production) ---

# Dev-instance keys. Map to the platform's own CLERK_SECRET_KEY /
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY names when set on Railway/Vercel for
# local, staging, and Preview environments. Mint: Clerk dashboard -> dev
# instance -> API Keys.
CLERK_DEV_PUBLISHABLE_KEY=
CLERK_DEV_SECRET_KEY=

# Prod-instance keys, same mapping, set only on the production
# environment. Mint: Clerk dashboard -> prod instance -> API Keys.
CLERK_PROD_PUBLISHABLE_KEY=
CLERK_PROD_SECRET_KEY=

# --- Email: Resend ---

# Sends from notifications@domainproof.dev — DKIM/SPF already verified on
# the zone. Mint: Resend dashboard -> API Keys.
RESEND_API_KEY=

# --- Demo ---

# dp_test_ key the public demo app (demo.domainproof.dev) calls the public
# API with. Disposable by design — regenerated every time the seed data is
# reset via `pnpm --filter api db:seed` (see infra-ops skill). Not
# sensitive the way the other values above are; still don't publish it
# unnecessarily.
DEMO_API_KEY=
