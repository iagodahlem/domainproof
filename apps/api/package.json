{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "tsx --env-file-if-exists=.env src/infra/db/reset.ts"
  },
  "dependencies": {
    "@domainproof/core": "workspace:*",
    "@hono/node-server": "^2.0.10",
    "@react-email/render": "^2.1.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "react": "^19.1.0",
    "resend": "^6.17.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "pino-pretty": "^13.1.3",
    "tsup": "catalog:",
    "tsx": "^4.23.1",
    "typescript": "catalog:",
    "typescript-eslint": "^8.64.0",
    "vitest": "catalog:"
  }
}
