{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "tsx --env-file-if-exists=.env src/infra/db/reset.ts",
    "db:seed": "tsx --env-file-if-exists=.env src/seed.ts"
  },
  "dependencies": {
    "@domainproof/core": "workspace:*",
    "@domainproof/mcp": "workspace:*",
    "@domainproof/sdk": "workspace:*",
    "@hono/node-server": "^2.0.10",
    "@hono/standard-validator": "^0.2.3",
    "@react-email/render": "^2.1.0",
    "@standard-community/standard-json": "^0.3.5",
    "@standard-community/standard-openapi": "^0.2.9",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "hono-openapi": "^1.3.1",
    "jose": "^6.2.3",
    "openapi-types": "^12.1.3",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "react": "^19.1.0",
    "resend": "^6.17.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@redocly/cli": "^2.40.0",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^26.1.1",
    "@types/react": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "pino-pretty": "^13.1.3",
    "tsup": "catalog:",
    "tsx": "^4.23.1",
    "typescript": "catalog:",
    "typescript-eslint": "^8.64.0",
    "vitest": "catalog:"
  }
}
