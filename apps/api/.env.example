# Matches the postgres service in the repo's compose.yaml.
DATABASE_URL=postgres://domainproof:domainproof@localhost:5432/domainproof

# Optional for now. The Clerk auth middleware returns a 500 with a clear
# error code if a route uses it while these are unset.
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# CLERK_ISSUER=https://your-instance.clerk.accounts.dev

# Optional, production-only. When set, each plane answers only on its own
# hostname (public /v1 vs dashboard /dashboard); unset means no host
# restriction — local dev, tests, and Railway's *.up.railway.app domain
# all leave these unset.
# PUBLIC_API_HOST=api.domainproof.dev
# DASHBOARD_API_HOST=dashboard.api.domainproof.dev
# FRONTEND_API_HOST=frontend.api.domainproof.dev

# Optional. The dashboard web app's origin, for the dashboard plane's CORS
# policy — the only plane a browser calls directly. Unset allows any
# origin, which is what keeps local dev and tests working with no config.
# WEB_ORIGIN=https://domainproof.dev

# Optional. Enables the Resend email notification subscribers (welcome,
# domain verified, grace window started, verification failed) — unset
# means they're never registered, so the app boots and every request path
# still works, just without emails sent.
# RESEND_API_KEY=re_...

# Optional, defaults to the address below (the domain this repo's Resend
# account is verified for).
# EMAIL_FROM=DomainProof <notifications@domainproof.dev>

# Optional, defaults to info. One of fatal|error|warn|info|debug|trace.
# debug additionally logs sanitized request/response payloads (see
# shared/middlewares/request-logger.ts) — headers and key-shaped fields are
# redacted and oversized bodies truncated, but it's noisy, so it's opt-in.
# LOG_LEVEL=info

# Optional, defaults to 5. Total webhook delivery attempts (including the
# first) before a delivery is marked `failed` for good — see README.md's
# Webhooks section for the retry schedule.
# WEBHOOK_MAX_ATTEMPTS=5

# Optional, defaults to enabled. The background recheck scheduler
# (pending backoff, verified continuous re-check, temporarily_failed
# grace-window expiry) ticks every RECHECK_INTERVAL_MS and processes up
# to RECHECK_BATCH_SIZE domains per batch. Set RECHECK_ENABLED=false to
# disable it, e.g. against a short-lived test/dev database.
# RECHECK_ENABLED=false
# RECHECK_INTERVAL_MS=60000
# RECHECK_BATCH_SIZE=10

# Both optional, and both required together. Private OAuth client
# credentials for the Cloudflare one-click DNS setup flow (see README's
# Cloudflare setup section for the one-time dashboard steps to mint
# these). Unset means the `/frontend/verifications/:token/cloudflare/authorize`
# and `/frontend/cloudflare/callback` routes respond 404 not_configured
# instead of the app refusing to boot.
# CLOUDFLARE_OAUTH_CLIENT_ID=
# CLOUDFLARE_OAUTH_CLIENT_SECRET=
