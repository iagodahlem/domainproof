# Matches the postgres service in the repo's compose.yaml.
DATABASE_URL=postgres://domainproof:domainproof@localhost:5432/domainproof

# Optional for now. The Clerk auth middleware returns a 500 with a clear
# error code if a route uses it while these are unset.
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# CLERK_ISSUER=https://your-instance.clerk.accounts.dev

# Optional, production-only. When set, each plane answers only on its own
# hostname (public /v1 vs dashboard /dashboard); unset means no host
# restriction — local dev, tests, and Railway's *.up.railway.app domain
# all leave these unset.
# PUBLIC_API_HOST=api.domainproof.dev
# DASHBOARD_API_HOST=dashboard.api.domainproof.dev

# Optional. Enables the Resend email notification subscribers (welcome,
# domain verified, grace window started, verification failed) — unset
# means they're never registered, so the app boots and every request path
# still works, just without emails sent.
# RESEND_API_KEY=re_...

# Optional, defaults to the address below (the domain this repo's Resend
# account is verified for).
# EMAIL_FROM=DomainProof <notifications@domainproof.dev>
