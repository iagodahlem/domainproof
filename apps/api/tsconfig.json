{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "paths": {
      "@apis/*": ["./src/apis/*"],
      "@infra/*": ["./src/infra/*"],
      "@modules/*": ["./src/modules/*"],
      "@shared/*": ["./src/shared/*"],
      "@workers/*": ["./src/workers/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
