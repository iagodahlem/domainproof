# Dashboard API base URL. Local default matches apps/api's default PORT.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Clerk — dev instance (local + staging; see README's Environments table
# for the prod instance, which is configured separately on Vercel).
# Google-only: no email/password strategy is enabled on this instance.
# These keys and apps/api's CLERK_JWKS_URL/CLERK_ISSUER must come from the
# same Clerk instance, and NEXT_PUBLIC_API_URL above must point at an api
# configured with that instance — locally that's normally one dev instance
# for both. Mismatched instances make the api reject every session token
# this app sends it.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
