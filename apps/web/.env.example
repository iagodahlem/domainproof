# Dashboard API base URL. Local default matches apps/api's default PORT.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Clerk — dev instance (local + staging; see README's Environments table
# for the prod instance, which is configured separately on Vercel).
# Google-only: no email/password strategy is enabled on this instance.
# These keys and apps/api's CLERK_JWKS_URL/CLERK_ISSUER must come from the
# same Clerk instance, and NEXT_PUBLIC_API_URL above must point at an api
# configured with that instance — locally that's normally one dev instance
# for both. Mismatched instances make the api reject every session token
# this app sends it.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Base URL of the Frontend API plane (serves /frontend/*) that the hosted
# verification page (/verify/[token]) calls directly from the browser.
# Defaults to http://localhost:3001 if unset, matching the api's local dev
# port — set this in production to https://frontend.api.domainproof.dev.
NEXT_PUBLIC_FRONTEND_API_URL=http://localhost:3001

# Server-only. A test-mode DomainProof API key (dp_test_...) the /demo
# consumer app uses via @domainproof/sdk to claim domains and mint
# component sessions on a visitor's behalf — never exposed to the browser.
# Create a project and key the same way any integration would: sign in to
# the dashboard, create a project, and copy its test key from Settings.
# Required for POST /demo/api/claim and GET /demo/api/status; POST
# /demo/api/scan works without it.
DEMO_DOMAINPROOF_API_KEY=dp_test_...

# Optional. Overrides the SDK's own production default
# (https://api.domainproof.dev) for the /demo consumer app. Unset already
# defaults to http://localhost:3001 under `next dev` (NODE_ENV=development);
# set this explicitly for staging/preview, where NODE_ENV is production.
# DEMO_DOMAINPROOF_BASE_URL=http://localhost:3001
